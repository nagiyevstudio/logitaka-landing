---
// src/layouts/MainLayout.astro
import '../styles/all.css';
import Header from '../components/Header.jsx';
import Footer from '../components/Footer.jsx';
import { getT, detectLocale } from '../utils/i18n.js';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const { 
  title = "Logitaka", 
  description = "Logitaka - AI-driven platform", 
  lang: propLang = undefined
} = Astro.props;

const accept = Astro.request && Astro.request.headers ? Astro.request.headers.get('accept-language') : null;
const lang = propLang || detectLocale(accept);

// Set server-side global language for the react-i18next mock during SSR
globalThis.currentLanguage = lang;

const t = getT(lang);

// Statically retrieve i18n configurations
const navItems = t('landing.ui.nav') || [];
const brandTagline = t('landing.ui.brandTagline');
const loginLabel = t('landing.ui.login');

const footerNavItems = t('landing.footer.nav') || [];
const footerLegalItems = t('landing.footer.legal') || [];
const footerTagline = t('landing.footer.tagline');
const footerCopyright = t('landing.footer.copyright');
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://logitaka.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://logitaka.com/assets/og-image.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://logitaka.com/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://logitaka.com/assets/og-image.png" />

    <!-- Schema.org JSON-LD for SoftwareApplication -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Logitaka",
        "operatingSystem": "All",
        "applicationCategory": "BusinessApplication",
        "description": "Logitaka is a voice-first cognitive exoskeleton and project operating system that structures raw audio thoughts into clean tasks, calendar events, and roadmaps.",
        "offers": {
          "@type": "Offer",
          "price": "4.99",
          "priceCurrency": "USD"
        }
      }
    </script>
  </head>
  <body>
    <!-- Set client-side global language and theme before any hydration runs -->
    <script is:inline define:vars={{ lang }}>
      (function() {
        globalThis.currentLanguage = lang;
        const savedTheme = localStorage.getItem('logitaka-landing-theme');
        const theme = savedTheme || (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.body.setAttribute('data-theme', theme);
      })();
    </script>
    <div class="site-shell">
      <Header client:load lang={lang} navItems={navItems} brandTagline={brandTagline} loginLabel={loginLabel} />
      <main>
        <slot />
      </main>
      <Footer lang={lang} navItems={footerNavItems} legalItems={footerLegalItems} brandTagline={brandTagline} tagline={footerTagline} copyright={footerCopyright} />
    </div>

    <!-- Performant native scroll reveal script -->
    <script>
      const setupReveal = () => {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );

        const elements = document.querySelectorAll('.reveal');
        elements.forEach((el) => revealObserver.observe(el));
      };

      // Initial load setup
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupReveal);
      } else {
        setupReveal();
      }
    </script>
  </body>
</html>
