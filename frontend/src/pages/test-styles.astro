---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Logitaka - Style Verification" lang="en">
  <div style="padding: 4rem 2rem; max-width: 1200px; margin: 0 auto;">
    <h1 style="font-size: 3rem; margin-bottom: 1.5rem; background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
      Logitaka Style Verification
    </h1>
    <p style="font-size: 1.2rem; margin-bottom: 3rem; color: var(--color-text-muted);">
      This page verifies that Vanilla CSS styles, fonts, and variables copy correctly from the original React application.
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 4rem;">
      <!-- Glassmorphic Card (ContextCard style preview) -->
      <div class="card reveal is-visible" style="padding: 2rem; border-radius: 16px; border: 1px solid var(--color-border); background: var(--color-bg-card); backdrop-filter: blur(12px);">
        <h3 style="font-size: 1.5rem; margin-bottom: 1rem; color: var(--color-text);">Glassmorphism Card</h3>
        <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
          Testing background variables, borders, and backdrop blur.
        </p>
        <button class="btn btn-primary" style="padding: 0.8rem 1.5rem; font-weight: 600; cursor: pointer;">
          Primary Action
        </button>
      </div>

      <!-- Accent Card -->
      <div class="card reveal is-visible" style="padding: 2rem; border-radius: 16px; border: 1px solid var(--color-primary-light); background: linear-gradient(145deg, var(--color-bg-card), rgba(var(--color-primary-rgb), 0.05));">
        <h3 style="font-size: 1.5rem; margin-bottom: 1rem; color: var(--color-text);">Theme Variables</h3>
        <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">
          Testing primary accent integration and gradient overlays.
        </p>
        <button class="btn btn-secondary" style="padding: 0.8rem 1.5rem; font-weight: 600; cursor: pointer;">
          Secondary Action
        </button>
      </div>
    </div>
  </div>
</MainLayout>
