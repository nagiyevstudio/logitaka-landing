---
import MainLayout from '../layouts/MainLayout.astro';
import { getT, detectLocale } from '../utils/i18n';
import Hero from '../components/home/Hero.jsx';
import Problem from '../components/home/Problem.jsx';
import HowItWorks from '../components/home/HowItWorks.jsx';
import Pricing from '../components/home/Pricing.jsx';
import FAQ from '../components/home/FAQ.jsx';
import FinalCTA from '../components/home/FinalCTA.jsx';

const accept = Astro.request && Astro.request.headers ? Astro.request.headers.get('accept-language') : null;
const lang = detectLocale(accept);
globalThis.currentLanguage = lang;
const t = getT(lang);
---

<MainLayout title={t('landing.meta.title')} description={t('landing.meta.description')} lang={lang}>
  <Hero />
  <Problem />
  <HowItWorks client:visible />
  <Pricing />
  <FAQ />
  <FinalCTA />
</MainLayout>
