---
// src/layouts/LegalLayout.astro
import MainLayout from './MainLayout.astro';

const { frontmatter } = Astro.props;
const title = frontmatter?.title || Astro.props.title || "Logitaka";
const lang = frontmatter?.lang || Astro.props.lang || "en";
---

<MainLayout title={`${title} — Logitaka`} lang={lang}>
  <main class="content-inner legal-content">
    <slot />
  </main>
</MainLayout>
